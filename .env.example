# ATC Tracker — Credentials Template
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → copy the token it gives you
# 2. Message @userinfobot on Telegram → it replies with your numeric chat ID
# 3. Send /start to your new bot at least once so it can message you
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord ───────────────────────────────────────────────────────────────────
# Full walkthrough in DISCORD.md. Summary:
# 1. Create an application + bot at https://discord.com/developers/applications
# 2. Bot tab → copy the token
# 3. OAuth2 → URL Generator: scope "bot", permissions "View Channel",
#    "Send Messages", "Embed Links", "Read Message History" — open the
#    generated URL to invite the bot to your server. Embed Links is easy to
#    miss and required — almost every message this bot sends is an embed.
# 4. Create 6 text channels: one per station below + #alerts + #commands
#    (make #commands private — deny @everyone View Channel, allow the bot)
# 5. Enable Developer Mode (User Settings → Advanced) then right-click each
#    channel → Copy Channel ID
DISCORD_BOT_TOKEN=
DISCORD_ALERTS_CHANNEL_ID=
DISCORD_COMMANDS_CHANNEL_ID=
DISCORD_CHANNEL_YBCG=
DISCORD_CHANNEL_YSPT=
DISCORD_CHANNEL_YSSY=
DISCORD_CHANNEL_YBBN=

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required to download Whisper models (free account is fine).
# 1. Sign up at https://huggingface.co
# 2. Go to https://huggingface.co/settings/tokens
# 3. Create a token (read-only access is sufficient)
HUGGINGFACE_TOKEN=
